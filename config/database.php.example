<?php
// config/database.php.example
// Rename this to database.php and fill in your credentials

$host = "your_host";
$user = "your_username";
$pass = "your_password";
$db   = "your_database_name";

$conn = mysqli_connect($host, $user, $pass, $db);

if (!$conn) {
    die("Database connection failed: " . mysqli_connect_error());
}
?>
